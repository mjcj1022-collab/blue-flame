# Copy to .env and fill in. Nothing here is committed.

# Postgres connection string (Neon, Supabase, RDS, Railway, or local)
DATABASE_URL=postgres://user:password@host:5432/blueflame

# Stripe — from dashboard.stripe.com/apikeys (use test keys first)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# JWT signing secret — generate a long random string
JWT_SECRET=change-me-to-a-64-char-random-string

# Where the client is served (for CORS)
CLIENT_ORIGIN=https://mjcj1022-collab.github.io

PORT=8787
